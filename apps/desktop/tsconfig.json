{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "src-tauri"],
  "references": [
    { "path": "../../packages/hwpx-codec" },
    { "path": "../../packages/hwpx-schema" },
    { "path": "../../packages/hwpx-editor" },
    { "path": "../../packages/hwpx-platform" }
  ]
}
