{
  "name": "@hwpx/codec",
  "version": "0.0.0",
  "description": "HWPX (OWPML / KS X 6101) parser and serializer — pure TypeScript",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
