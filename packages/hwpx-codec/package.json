    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "fast-check": "^3.22.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
