{
  "name": "@hwpx/platform",
  "version": "0.0.0",
  "description": "Platform adapter abstraction (web / tauri / memory) for hwpx-editor",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/adapters/web.d.ts",
      "import": "./dist/adapters/web.js"
    },
    "./tauri": {
      "types": "./dist/adapters/tauri.d.ts",
      "import": "./dist/adapters/tauri.js"
    },
    "./memory": {
      "types": "./dist/adapters/memory.d.ts",
      "import": "./dist/adapters/memory.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.1.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    },
    "@tauri-apps/plugin-dialog": {
      "optional": true
    },
    "@tauri-apps/plugin-fs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.1.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
